[Unit]
Description=Mainsail UI – Dual Filament S6 (port 8082)
After=network-online.target moonraker-dual-filament.service

[Service]
Type=simple
WorkingDirectory=/home/per/mainsail-dual-filament
ExecStart=/usr/bin/python3 -m http.server 8082 --bind 0.0.0.0
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
